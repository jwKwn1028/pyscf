from pyscf.dft import dks as dks
from pyscf.x2c import x2c as x2c
from pyscf.gto.mole import Mole

class UKS(dks.KohnShamDFT, x2c.UHF):
    def __init__(self, mol: Mole, xc: str = 'LDA,VWN') -> None: ...
    def dump_flags(self, verbose: None=None) -> "UKS": ...
    def to_hf(self): ...
X2C_UKS = UKS

class RKS(dks.KohnShamDFT, x2c.RHF):
    def __init__(self, mol, xc: str = 'LDA,VWN') -> None: ...
    def dump_flags(self, verbose=None): ...
    def to_hf(self): ...
X2C_RKS = RKS
