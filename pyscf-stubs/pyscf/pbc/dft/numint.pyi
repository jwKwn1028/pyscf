def eval_ao(cell: Cell, coords: ndarray, kpt: ndarray=..., deriv: int = 0, relativity: int = 0, shls_slice: Optional[Tuple[int, int]]=None, non0tab: Optional[ndarray]=None, cutoff: Optional[float]=None, out: None=None, verbose: None=None) -> ndarray: ...
