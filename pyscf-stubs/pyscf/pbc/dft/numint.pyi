def nr_rks_fxc_st(ni: Union[KNumInt, NumInt], cell: Cell, grids: Union[UniformGrids, BeckeGrids], xc_code: str, dm0: Optional[ndarray], dms_alpha: ndarray, hermi: int = 0, singlet: bool = True, rho0: Optional[ndarray]=None, vxc: Optional[ndarray]=None, fxc: Optional[ndarray]=None, kpts: Optional[ndarray]=None, max_memory: Union[float, int] = 2000, verbose: None=None) -> ndarray: ...
