class NumInt(lib.StreamObject, numint.LibXCMixin):
    cutoff: Incomplete
    def reset(self, cell: Optional[Cell]=None) -> "NumInt": ...
    def nr_vxc(self, cell, grids, xc_code, dms, spin: int = 0, relativity: int = 0, hermi: int = 1, kpt=None, kpts_band=None, max_memory: int = 2000, verbose=None): ...
    get_vxc = nr_vxc
    def nr_rks(self, cell: Cell, grids: Union[UniformGrids, BeckeGrids], xc_code: str, dms: Union[ndarray, NPArrayWithTag], relativity: int = 0, hermi: int = 1, kpt: ndarray=..., kpts_band: None=None, max_memory: Union[float, int] = 2000, verbose: None=None) -> Tuple[float64, float64, ndarray]: ...
    def nr_uks(self, cell: Cell, grids: Union[UniformGrids, BeckeGrids], xc_code: str, dms: Union[ndarray, NPArrayWithTag, Tuple[ndarray, ndarray]], relativity: int = 0, hermi: int = 1, kpt: ndarray=..., kpts_band: None=None, max_memory: Union[float, int] = 2000, verbose: None=None) -> Tuple[ndarray, float64, ndarray]: ...
    def nr_fxc(self, cell, grids, xc_code, dm0, dms, spin: int = 0, relativity: int = 0, hermi: int = 0, rho0=None, vxc=None, fxc=None, kpt=None, max_memory: int = 2000, verbose=None): ...
    get_fxc = nr_fxc
    def cache_xc_kernel(self, cell: Cell, grids: Union[UniformGrids, BeckeGrids], xc_code: str, mo_coeff: Union[ndarray, Tuple[ndarray, ndarray]], mo_occ: Union[ndarray, Tuple[ndarray, ndarray]], spin: int = 0, kpt: Optional[ndarray]=None, max_memory: int = 2000) -> Tuple[ndarray, ndarray, ndarray]: ...
    def cache_xc_kernel1(self, cell: Cell, grids: UniformGrids, xc_code: str, dm: ndarray, spin: int = 0, kpt: None=None, max_memory: int = 2000) -> Tuple[ndarray, ndarray, ndarray]: ...
    def block_loop(self, cell: Cell, grids: Union[UniformGrids, BeckeGrids], nao: Optional[int]=None, deriv: int = 0, kpt: Optional[ndarray]=None, kpts_band: None=None, max_memory: Union[float, int] = 2000, non0tab: None=None, blksize: None=None) -> Iterator[Tuple[ndarray, ndarray, ndarray, ndarray, ndarray]]: ...
    nr_rks_fxc = nr_rks_fxc
    nr_uks_fxc = nr_uks_fxc
    nr_rks_fxc_st = nr_rks_fxc_st
    nr_nlc_vxc = nr_nlc_vxc
    make_mask: Incomplete
    eval_ao: Incomplete
    eval_rho: Incomplete
    eval_rho2: Incomplete
    get_rho = get_rho
    def eval_rho1(self, cell: Cell, ao: ndarray, dm: ndarray, screen_index: Optional[ndarray]=None, xctype: str = 'LDA', hermi: int = 0, with_lapl: bool = True, cutoff: None=None, ao_cutoff: None=None, verbose: None=None) -> ndarray: ...
    def to_gpu(self): ...

class KNumInt(lib.StreamObject, numint.LibXCMixin):
    def __init__(self, *args, **kwargs) -> None: ...
    def reset(self, cell: Optional[Cell]=None) -> "KNumInt": ...
    eval_ao: Incomplete
    def make_mask(self, cell, coords, relativity: int = 0, shls_slice=None, verbose=None): ...
    def eval_rho(self, cell: Cell, ao_kpts: List[ndarray], dm_kpts: ndarray, non0tab: Optional[ndarray]=None, xctype: str = 'LDA', hermi: int = 0, with_lapl: bool = True, verbose: None=None) -> ndarray: ...
    def eval_rho1(self, cell: Cell, ao_kpts: List[ndarray], dm_kpts: ndarray, non0tab: Optional[ndarray]=None, xctype: str = 'LDA', hermi: int = 0, with_lapl: bool = True, cutoff: float=..., grids: None=None, verbose: None=None) -> ndarray: ...
    def eval_rho2(self, cell: Cell, ao_kpts: Union[ndarray, List[ndarray]], mo_coeff_kpts: Union[ndarray, List[Union[NPArrayWithTag, ndarray]], List[ndarray]], mo_occ_kpts: Union[ndarray, List[ndarray]], non0tab: Optional[ndarray]=None, xctype: str = 'LDA', with_lapl: bool = True, verbose: None=None) -> ndarray: ...
    def nr_vxc(self, cell, grids, xc_code, dms, spin: int = 0, relativity: int = 0, hermi: int = 1, kpts=None, kpts_band=None, max_memory: int = 2000, verbose=None): ...
    get_vxc = nr_vxc
    def nr_rks(self, cell: Cell, grids: Union[UniformGrids, BeckeGrids], xc_code: str, dms: Union[ndarray, NPArrayWithTag, List[ndarray]], relativity: int = 0, hermi: int = 1, kpts: Optional[Union[ndarray, KPoints]]=None, kpts_band: Optional[ndarray]=None, max_memory: Union[float, int] = 2000, verbose: None=None, **kwargs) -> Union[Tuple[float64, float64, ndarray], Tuple[int, int, int], Tuple[ndarray, ndarray, ndarray]]: ...
    def nr_uks(self, cell: Cell, grids: Union[UniformGrids, BeckeGrids], xc_code: str, dms: Union[ndarray, NPArrayWithTag, Tuple[ndarray, ndarray]], relativity: int = 0, hermi: int = 1, kpts: Optional[Union[ndarray, KPoints]]=None, kpts_band: Optional[ndarray]=None, max_memory: Union[float, int] = 2000, verbose: None=None, **kwargs) -> Union[Tuple[ndarray, float64, ndarray], Tuple[int, int, ndarray]]: ...
    def nr_fxc(self, cell, grids, xc_code, dm0, dms, spin: int = 0, relativity: int = 0, hermi: int = 0, rho0=None, vxc=None, fxc=None, kpts=None, max_memory: int = 2000, verbose=None): ...
    get_fxc = nr_fxc
    def block_loop(self, cell: Cell, grids: Union[UniformGrids, BeckeGrids], nao: Optional[int]=None, deriv: int = 0, kpts: Optional[ndarray]=None, kpts_band: Optional[ndarray]=None, max_memory: Union[float, int] = 2000, non0tab: None=None, blksize: None=None) -> Iterator[Tuple[List[ndarray], List[ndarray], ndarray, ndarray, ndarray]]: ...
    nr_rks_fxc = nr_rks_fxc
    nr_uks_fxc = nr_uks_fxc
    nr_rks_fxc_st = nr_rks_fxc_st
    cache_xc_kernel = cache_xc_kernel
    cache_xc_kernel1 = cache_xc_kernel1
    get_rho = get_rho
    def to_gpu(self): ...
