def eval_rho2(cell: Cell, ao: ndarray, mo_coeff: Union[ndarray, NPArrayWithTag], mo_occ: ndarray, non0tab: Optional[ndarray]=None, xctype: str = 'LDA', with_lapl: bool = True, verbose: None=None) -> ndarray: ...
