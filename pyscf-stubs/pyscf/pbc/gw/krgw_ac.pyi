def kernel(gw: "KRGWAC", mo_energy: ndarray, mo_coeff: ndarray, orbs: Optional[range]=None, kptlist: Optional[List[int]]=None, nw: Optional[int]=None, verbose: int=...) -> Tuple[bool, ndarray, ndarray]: ...
def get_rho_response(gw: "KRGWAC", omega: float64, mo_energy: ndarray, Lpq: ndarray, kL: int, kidx: ndarray) -> ndarray: ...
def get_sigma_diag(gw: "KRGWAC", orbs: range, kptlist: List[int], freqs: ndarray, wts: ndarray, iw_cutoff: Optional[float]=None, max_memory: int = 8000) -> Tuple[ndarray, ndarray]: ...
def get_rho_response_head(gw: "KRGWAC", omega: float64, mo_energy: ndarray, qij: ndarray) -> complex128: ...
def get_rho_response_wing(gw: "KRGWAC", omega: float64, mo_energy: ndarray, Lpq: ndarray, qij: ndarray) -> ndarray: ...
