def two_pole_fit(coeff, omega, sigma): ...
def two_pole(freqs, coeff): ...
def AC_twopole_diag(sigma, omega, orbs, nocc): ...
def thiele(fn: ndarray, zn: ndarray) -> ndarray: ...
