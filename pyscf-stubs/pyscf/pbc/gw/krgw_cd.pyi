def kernel(gw: "KRGWCD", mo_energy: ndarray, mo_coeff: ndarray, orbs: Optional[range]=None, kptlist: Optional[List[int]]=None, nw: Optional[int]=None, verbose: int=...) -> Tuple[bool, ndarray, ndarray]: ...
def get_sigma_diag(gw: "KRGWCD", ep: float64, kp: int, p: int, Wmn: ndarray, Del_00: Optional[ndarray], Del_P0: Optional[ndarray], freqs: ndarray, wts: ndarray, qij: Optional[ndarray], q_abs: Optional[ndarray]) -> complex128: ...
