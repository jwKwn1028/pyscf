def get_WmnI_diag(gw: "KRGWCD", orbs: range, kptlist: List[int], freqs: ndarray, max_memory: int = 8000) -> Union[Tuple[ndarray, ndarray, ndarray, ndarray, ndarray], Tuple[ndarray, None, None, None, None]]: ...
def get_sigmaI_diag(gw: "KRGWCD", omega: float64, kp: int, p: int, Wmn: ndarray, Del_00: Optional[ndarray], Del_P0: Optional[ndarray], sign: ndarray, freqs: ndarray, wts: ndarray) -> complex128: ...
def get_rho_response_R(gw: "KRGWCD", omega: float64, mo_energy: ndarray, Lpq: ndarray, kL: int, kidx: ndarray) -> ndarray: ...
def get_sigmaR_diag(gw: "KRGWCD", omega: float64, kn: int, orbp: int, ef: float64, freqs: ndarray, qij: Optional[ndarray], q_abs: Optional[ndarray]) -> Union[complex128, complex]: ...
