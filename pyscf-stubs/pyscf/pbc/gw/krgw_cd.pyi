def get_qij(gw: "KRGWCD", q: ndarray, mo_coeff: ndarray, uniform_grids: bool = False) -> ndarray: ...

class KRGWCD(lib.StreamObject):
    linearized: Incomplete
    eta: Incomplete
    fc: Incomplete
    mol: Incomplete
    verbose: Incomplete
    stdout: Incomplete
    max_memory: Incomplete
    frozen: Incomplete
    with_df: Incomplete
    kpts: Incomplete
    nkpts: Incomplete
    mo_energy: Incomplete
    mo_coeff: Incomplete
    mo_occ: Incomplete
    sigma: Incomplete
    def __init__(self, mf: KRKS, frozen: None=None) -> None: ...
    def dump_flags(self) -> "KRGWCD": ...
    @property
    def nocc(self): ...
    @nocc.setter
    def nocc(self, n) -> None: ...
    @property
    def nmo(self): ...
    @nmo.setter
    def nmo(self, n) -> None: ...
    get_nocc = get_nocc
    get_nmo = get_nmo
    get_frozen_mask = get_frozen_mask
    def kernel(self, mo_energy: None=None, mo_coeff: None=None, orbs: Optional[range]=None, kptlist: Optional[List[int]]=None, nw: int = 100) -> ndarray: ...
