class UCCSDT(ccsd.CCSDBase):
    __doc__ = __doc__
    conv_tol: Incomplete
    conv_tol_normt: Incomplete
    cc_order: int
    do_diis_max_t: Incomplete
    blksize_o_aaa: Incomplete
    blksize_v_aaa: Incomplete
    blksize_o_aab: Incomplete
    blksize_v_aab: Incomplete
    einsum_backend: Incomplete
    @property
    def t1(self): ...
    @t1.setter
    def t1(self, val) -> None: ...
    @property
    def t2(self): ...
    @t2.setter
    def t2(self, val) -> None: ...
    @property
    def t3(self): ...
    @t3.setter
    def t3(self, val) -> None: ...
    tamps: Incomplete
    unique_tamps_map: Incomplete
    def __init__(self, mf: Union[UHF, HF1e], frozen: Optional[List[List[int]]]=None, mo_coeff: None=None, mo_occ: None=None) -> None: ...
    do_tri_max_t: Incomplete
    def set_einsum_backend(self, backend) -> None: ...
    get_nocc = get_nocc
    get_nmo = get_nmo
    get_frozen_mask = get_frozen_mask
    get_e_hf = get_e_hf
    ao2mo: Incomplete
    energy = energy_uhf
    init_amps = init_amps_uhf
    restore_from_diis_ = restore_from_diis_
    memory_estimate_log = memory_estimate_log_uccsdt
    update_amps_ = update_amps_uccsdt_tri_
    amplitudes_to_vector = amplitudes_to_vector_uhf
    vector_to_amplitudes = vector_to_amplitudes_uhf
    build_unique_tamps_map = build_unique_tamps_map_uhf
    setup_tri2block = setup_tri2block_t3_uhf
    vector_size = vector_size_uhf
    run_diis = run_diis
    dump_flags = dump_flags
    dump_chk = dump_chk
    tamps_tri2full = tamps_tri2full_uhf
    tamps_full2tri = tamps_full2tri_uhf
    tamps_rhf2uhf = tamps_rhf2uhf
    tamps_uhf2rhf = tamps_uhf2rhf
    def kernel(self, tamps: Optional[List[List[ndarray]]]=None, eris: None=None) -> Tuple[NPArrayWithTag, List[List[ndarray]]]: ...
    e_hf: Incomplete
    def ccsdt(self, tamps: Optional[List[List[ndarray]]]=None, eris: None=None) -> Tuple[NPArrayWithTag, List[List[ndarray]]]: ...
    def ccsdt_q(self, tamps, eris=None) -> None: ...

