    get_h2eff: Incomplete
    def casci(self, mo_coeff: Union[ndarray, Tuple[ndarray, ndarray], Tuple[NPArrayWithTag, NPArrayWithTag]], ci0: Optional[Union[ndarray, FCIvector]]=None, eris: Optional[_ERIS]=None, verbose: Optional[Logger]=None, envs: Optional[Any]=None) -> Tuple[float64, float64, FCIvector]: ...
