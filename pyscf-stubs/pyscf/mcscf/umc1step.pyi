    def kernel(self, mo_coeff: None=None, ci0: None=None, callback: None=None, _kern: Callable=...) -> Union[Tuple[float64, float64, FCIvector, Tuple[ndarray, ndarray]], Tuple[float64, float64, FCIvector, ndarray], Tuple[float64, float64, FCIvector, Tuple[NPArrayWithTag, NPArrayWithTag]]]: ...
    def mc1step(self, mo_coeff: None=None, ci0: None=None, callback: None=None) -> Tuple[float64, float64, FCIvector, Tuple[NPArrayWithTag, NPArrayWithTag]]: ...
