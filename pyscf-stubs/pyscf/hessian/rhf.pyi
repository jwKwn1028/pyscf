from _typeshed import Incomplete
from pyscf import gto as gto, lib as lib, scf as scf
from pyscf.grad import rhf as rhf
from pyscf.lib import logger as logger
from pyscf.scf import cphf as cphf, hf as hf
from numpy import int64, ndarray
from pyscf.dft.rks import RKS
from pyscf.dft.uks import UKS
from pyscf.gto.mole import Mole
from pyscf.hessian.rks import Hessian
from pyscf.lib.logger import Logger
from pyscf.scf.hf import RHF
from pyscf.scf.uhf import UHF
from typing import Callable, List, Optional, Tuple, Union

def hess_elec(hessobj: Union[Hessian, Hessian], mo_energy: Optional[ndarray]=None, mo_coeff: Optional[ndarray]=None, mo_occ: Optional[ndarray]=None, mo1: None=None, mo_e1: None=None, h1ao: None=None, atmlst: Optional[Union[range, List[int]]]=None, max_memory: int = 4000, verbose: None=None) -> ndarray: ...
def partial_hess_elec(hessobj: "Hessian", mo_energy: Optional[ndarray]=None, mo_coeff: Optional[ndarray]=None, mo_occ: Optional[ndarray]=None, atmlst: Optional[Union[range, List[int]]]=None, max_memory: int = 4000, verbose: Optional[Logger]=None) -> ndarray: ...
def make_h1(hessobj: "Hessian", mo_coeff: ndarray, mo_occ: ndarray, chkfile: None=None, atmlst: Optional[Union[range, List[int]]]=None, verbose: Optional[Logger]=None) -> List[Optional[ndarray]]: ...
def get_hcore(mol: Mole) -> Tuple[ndarray, ndarray]: ...
def get_ovlp(mol: Mole) -> Tuple[ndarray, ndarray, ndarray]: ...
def solve_mo1(mf: Union[RHF, RKS], mo_energy: ndarray, mo_coeff: ndarray, mo_occ: ndarray, h1ao: Union[ndarray, List[Optional[ndarray]], List[ndarray]], fx: None=None, atmlst: Optional[Union[range, List[int]]]=None, max_memory: int = 4000, verbose: Optional[Logger]=None, max_cycle: int = 50, level_shift: Union[float, int] = 0) -> Union[Tuple[List[Optional[ndarray]], List[Optional[ndarray]]], Tuple[List[ndarray], List[ndarray]]]: ...
def gen_vind(mf: Union[RHF, RKS], mo_coeff: ndarray, mo_occ: ndarray) -> Callable: ...
def hess_nuc(mol: Mole, atmlst: Optional[Union[range, List[int]]]=None) -> ndarray: ...
def gen_hop(hobj, mo_energy=None, mo_coeff=None, mo_occ=None, verbose=None): ...

class HessianBase(lib.StreamObject):
    max_cycle: int
    level_shift: int
    verbose: Incomplete
    stdout: Incomplete
    mol: Incomplete
    base: Incomplete
    max_memory: Incomplete
    atmlst: Incomplete
    de: Incomplete
    def __init__(self, scf_method: Union[RHF, UKS, RKS, UHF]) -> None: ...
    def hess_elec(self, *args, **kwargs) -> None: ...
    def make_h1(self, *args, **kwargs) -> None: ...
    def get_hcore(self, mol: Optional[Mole]=None) -> Tuple[ndarray, ndarray]: ...
    def hcore_generator(self, mol: Optional[Mole]=None) -> Callable: ...
    def solve_mo1(self, mo_energy: ndarray, mo_coeff: ndarray, mo_occ: ndarray, h1ao: Union[ndarray, List[Optional[ndarray]], List[ndarray]], fx: None=None, atmlst: Optional[Union[range, List[int]]]=None, max_memory: int = 4000, verbose: Optional[Logger]=None) -> Union[Tuple[List[Optional[ndarray]], List[Optional[ndarray]]], Tuple[List[ndarray], List[ndarray]]]: ...
    def hess_nuc(self, mol: Optional[Mole]=None, atmlst: Optional[Union[range, List[int]]]=None) -> ndarray: ...
    def kernel(self, mo_energy: None=None, mo_coeff: None=None, mo_occ: None=None, atmlst: Optional[List[int]]=None) -> ndarray: ...
    hess = kernel
    gen_hop = gen_hop
    to_gpu = lib.to_gpu

class Hessian(HessianBase):
    partial_hess_elec = partial_hess_elec
    hess_elec = hess_elec
    make_h1 = make_h1
